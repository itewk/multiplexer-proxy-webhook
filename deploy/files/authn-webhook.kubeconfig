apiVersion: v1
kind: Config
clusters:
  - name: authn-webhook
    cluster:
      server: https://authn-webhook.apps.sno-auth-testing.lab.rh-itewk.internal
      certificate-authority-data: 
      tls-server-name: authn-webhook.apps.sno-auth-testing.lab.rh-itewk.internal
users:
  - name: authn-webhook
    user:
      token: "unused"
contexts:
  - name: authn-webhook
    context:
      cluster: authn-webhook
      user: authn-webhook
current-context: authn-webhook
